  "version": "0.2.0",
  "configurations": [
    
    
    {
      "name": "Launch Mergington WebApp",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "src.app:app",
        "--reload",
        "--reload-include",
        "src/static/*"
      ],
      "jinja": true
    }
      ,{
          "name": "Run FastAPI",
          "type": "python",
          "request": "launch",
          "module": "uvicorn",
          "args": [
            "src.app:app", // アプリケーションのエントリーポイント
            "--reload",    // 自動リロードを有効化
            "--host", "127.0.0.1", // ホストを指定
            "--port", "8000"       // ポートを指定
          ],
          "jinja": true
        }
  ]
}
